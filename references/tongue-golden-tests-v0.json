{
  "schema_version": "0.1",
  "parser": [
    {
      "input": "need file.read target:\"docs/charter.md\" because:\"verify before editing\"",
      "expected_speech_act": "need",
      "expected_payload": {
        "need": {
          "capability": "file.read",
          "target": "docs/charter.md"
        }
      }
    },
    {
      "input": "claim \"effect creation is not effect execution\" evidence:[state_machine]",
      "expected_speech_act": "claim",
      "expected_payload": {
        "claim": "effect creation is not effect execution"
      },
      "expected_evidence": ["state_machine"]
    },
    {
      "input": "doubt target_path because:\"may escape scope\"",
      "expected_speech_act": "doubt",
      "expected_payload": {
        "doubt": "target_path"
      },
      "expected_reason": "may escape scope"
    },
    {
      "input": "remember project \"scope must narrow on delegation\"",
      "expected_speech_act": "remember",
      "expected_payload": {
        "lifespan": "project",
        "memory_candidate": "scope must narrow on delegation"
      }
    },
    {
      "input": "boundary cannot commit effect:file.write reason:approval_missing offer:dry_run",
      "expected_speech_act": "boundary",
      "expected_payload": {
        "boundary": "cannot commit effect:file.write",
        "offer": "dry_run"
      },
      "expected_reason": "approval_missing"
    }
  ],
  "renderer": [
    {
      "record": {
        "schema_version": "0.1",
        "record_type": "proposal",
        "proposal_id": "gold_need_001",
        "actor": "agent:hermes",
        "speech_act": "need",
        "reason": "verify before editing",
        "confidence": 0.93,
        "evidence": ["rule:read_first"],
        "payload": {
          "utterance": "need file.read target:\"docs/charter.md\" because:\"verify before editing\"",
          "need": {
            "kind": "tool",
            "capability": "file.read",
            "target": "docs/charter.md"
          }
        }
      },
      "expected_contains": ["I need", "`file.read`", "`docs/charter.md`", "verify before editing", "Confidence: 0.93"]
    },
    {
      "record": {
        "schema_version": "0.1",
        "record_type": "proposal",
        "proposal_id": "gold_boundary_001",
        "actor": "agent:hermes",
        "speech_act": "boundary",
        "reason": "approval_missing",
        "confidence": 0.9,
        "evidence": ["approval:absent"],
        "payload": {
          "utterance": "boundary cannot commit effect:file.write reason:approval_missing offer:dry_run",
          "boundary": "cannot commit file.write without required approval",
          "offer": "render dry-run and request approval"
        }
      },
      "expected_contains": ["Boundary:", "cannot commit", "offer", "request approval"]
    }
  ],
  "file_write_adapter": [
    {
      "name": "allowed_write_commits",
      "expected_state": "committed",
      "expected_trace_contains": ["proposal.received", "intent.created", "policy.checked", "dry_run.rendered", "adapter.commit.started", "effect.committed"]
    },
    {
      "name": "path_escape_rejected",
      "expected_state": "rejected",
      "expected_reason": "path_outside_scope"
    },
    {
      "name": "missing_capability_rejected",
      "expected_state": "rejected",
      "expected_reason": "missing_capability"
    },
    {
      "name": "approval_required_pauses",
      "expected_state": "paused",
      "expected_required_input": "human_approval"
    }
  ]
}
